{
  "version": "2.0.0",
  "description": "Multi-Search-Engine configuration for BiliSum v6.0",
  "engines": {
    "bilibili": {
      "type": "bilibili",
      "enabled": true,
      "priority": 1,
      "region": "CN",
      "max_results": 20,
      "timeout": 15,
      "search_types": ["video", "article"],
      "cookie_required": false,
      "cookie_env": "BILIBILI_COOKIE"
    },
    "youtube": {
      "type": "youtube",
      "enabled": true,
      "priority": 3,
      "region": "Global",
      "max_results": 20,
      "timeout": 15,
      "api_key_env": "YOUTUBE_API_KEY",
      "fallback_instances": [
        "https://invidious.snopyta.org",
        "https://invidious.fdn.fr",
        "https://yewtu.be",
        "https://vid.puffyan.us"
      ]
    },
    "zhihu": {
      "type": "zhihu",
      "enabled": true,
      "priority": 2,
      "region": "CN",
      "max_results": 20,
      "timeout": 15,
      "cookie_env": "ZHIHU_COOKIE",
      "search_types": ["answer", "article", "question"],
      "api_endpoints": [
        "https://www.zhihu.com/api/v4/search_v3",
        "https://www.zhihu.com/search"
      ]
    },
    "web_search": {
      "type": "web_search",
      "enabled": true,
      "priority": 4,
      "region": "Global",
      "max_results": 20,
      "timeout": 15,
      "primary_provider": "brave",
      "secondary_provider": "firecrawl",
      "fallback_provider": "duckduckgo",
      "brave_api_key_env": "BRAVE_API_KEY",
      "firecrawl_api_key_env": "FIRECRAWL_API_KEY",
      "tracking_params_removed": [
        "utm_source", "utm_medium", "utm_campaign", "utm_term", "utm_content",
        "ref", "referrer", "source", "spm", "from", "tracking_id",
        "fbclid", "gclid", "msclkid", "igshid", "mc_cid", "mc_eid",
        "share_id", "share_medium", "share_source", "share_plat",
        "session_id", "timestamp"
      ]
    }
  },
  "fallback": {
    "enabled": true,
    "min_results_to_stop": 5,
    "max_depth": 4,
    "engine_timeout": 10,
    "chains": [
      ["bilibili"],
      ["bilibili", "zhihu"],
      ["bilibili", "zhihu", "youtube"],
      ["bilibili", "zhihu", "youtube", "web_search"]
    ]
  },
  "dedup": {
    "enabled": true,
    "threshold": 0.75,
    "title_weight": 0.6,
    "url_weight": 0.3,
    "fingerprint_weight": 0.1
  },
  "ranking": {
    "relevance_weight": 0.35,
    "quality_weight": 0.25,
    "freshness_weight": 0.15,
    "diversity_weight": 0.10,
    "depth_weight": 0.15,
    "recency_days": 365
  },
  "analytics": {
    "enabled": true,
    "db_path": "backend/data/search_history.db",
    "retention_days": 90,
    "max_history_size": 10000
  },
  "cross_leverage": {
    "bilibili_source": {
      "integration_point": "BilibiliEngine._search() can call bilibili-source skill for enriched metadata",
      "fields": ["view_count", "like_count", "coin_count", "favorite_count", "share_count", "reply_count", "follower_count"],
      "benefit": "Live stats improve quality ranking accuracy"
    },
    "firecrawl_deep_research": {
      "integration_point": "FirecrawlWebEngine results as seed URLs for firecrawl-deep-research",
      "trigger": "When multi_search returns web_search results with high relevance",
      "benefit": "Deep-dive reports from cross-platform aggregate"
    },
    "smart_categorize": {
      "integration_point": "Search results piped into smart-categorize classifier for auto-tagging",
      "benefit": "Multi-platform category diversity + search suggestions refinement"
    }
  }
}
